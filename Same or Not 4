/*Write a program to find the type of array as whether it is even, odd or mixed. If all the elements of an array are even, then display the array type as even. If all the elements of an array are odd, then display the array type as odd. If an array has both even and odd elements, then display the array type as mixed.

Input Format

Input consists of 1 integer and 1 array.
Integer corresponds to the size of the array.
Constraints

No Constraints

Output Format

print the statement whether the given array type is even, odd or mixed
Sample Input 0

5
9
2
1
3
5
Sample Output 0

Mixed
Sample Input 1

4
2
4
6
8
Sample Output 1

Even
Sample Input 2

3
1
3
5
Sample Output 2

Odd*/

#Answer

import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        
        int n = sc.nextInt();
        int[] arr = new int[n];
        
        boolean hasEven = false;
        boolean hasOdd = false;
        
        for(int i = 0; i < n; i++){
            arr[i] = sc.nextInt();
            
            if(arr[i] % 2 == 0){
                hasEven = true;
            } else {
                hasOdd = true;
            }
        }
        
        if(hasEven && hasOdd){
            System.out.println("Mixed");
        } 
        else if(hasEven){
            System.out.println("Even");
        } 
        else{
            System.out.println("Odd");
        }
    }
}

